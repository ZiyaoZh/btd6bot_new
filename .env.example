# Required by btd6bot_plugin
BOT_TARGET_GROUP_ID=123456789
BOT_TARGET_GROUP_IDS=123456789
BOT_QQ=
BOT_NAME=BTD6Bot

# LLM provider. Any OpenAI-compatible endpoint is supported by the plugin.
LLM_API_KEY=replace_me
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_REQUEST_TIMEOUT=30
LLM_HISTORY_TURNS=6
LLM_MAX_REPLY_CHARS=1200

# Optional Ninja Kiwi Open Data key for activity tooling.
NK_API_KEY=

# Plugin runtime paths inside the container.
BOT_MANUAL_FILE=manuals/program_manual.md
BOT_COMMAND_GUIDE_DIR=command_skills
BOT_DB_FILE=data/bot_data.db
BOT_FLOW_LOG_FILE=logs/network.log
BOT_MAX_TOOL_ROUNDS=4
BOT_PROACTIVE_CHAT_ENABLED=true
BOT_GAME_NEWS_REFRESH_INTERVAL_SECONDS=600
