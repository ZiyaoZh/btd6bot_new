# 指定机器人监听的群号
BOT_TARGET_GROUP_ID=123456
BOT_TARGET_GROUP_IDS=123456

# 机器人 QQ 号（可选，用于忽略自己发出的消息）
BOT_QQ=123456

# 机器人名称（用于管理员指令中的 @机器人名 校验）
BOT_NAME=小污猫

# 说明书文件路径（用于 manual_query 指令）
BOT_MANUAL_FILE=manuals/program_manual.md

# 本地指令教程目录（供指令引导查询）
BOT_COMMAND_GUIDE_DIR=command_skills

# LLM 与指令处理器多轮交互最大轮次
BOT_MAX_TOOL_ROUNDS=10

# 是否开启主动接话（false 时仅响应 @机器人 的消息）
BOT_PROACTIVE_CHAT_ENABLED=false

# 活动数据后台刷新间隔（秒），机器人启动后会自动定时刷新
BOT_GAME_NEWS_REFRESH_INTERVAL_SECONDS=600

# 机器人轻量数据库文件路径
BOT_DB_FILE=data/bot_data.db

# 触发前缀（留空表示群内所有消息都走 LLM）
BOT_TRIGGER_PREFIX=

# 流水日志文件（记录完整数据传输流程）
BOT_FLOW_LOG_FILE=logs/network.log

# OpenAI 兼容接口配置
LLM_API_KEY=replace_me
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 可选项
LLM_REQUEST_TIMEOUT=30
LLM_HISTORY_TURNS=6
LLM_MAX_REPLY_CHARS=1200
LLM_MAX_RETRIES=20

# 路由规划器常见问题-工具映射提示词（Markdown）
LLM_ROUTER_TOOL_HINTS_FILE=prompts/router_tool_hints.md

# 系统提示词（推荐使用 Markdown 文件）
LLM_SYSTEM_PROMPT_FILE=prompts/system_prompt.md
